  const keys = ["pref_conv_style","pref_partner_level","pref_availability","pref_wants_correction","pref_open_to_teach","pref_exchange_only","pref_show_translation","pref_auto_play_audio","pref_send_with_enter","pref_read_receipts","pref_typing_indicator","pref_font_size","pref_bubble_style","pref_chat_bg","pref_goals_week"];

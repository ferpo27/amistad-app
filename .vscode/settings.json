{
  // Preferencias de importación para TypeScript
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  // Preferencias de importación para JavaScript
  "javascript.preferences.importModuleSpecifier": "relative",
  "javascript.preferences.importModuleSpecifierEnding": "js",
  // Mapeos de rutas que deben coincidir con los definidos en tsconfig.json
  // Ejemplo: alias "@" que apunta a la carpeta src
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  // Si tu tsconfig.json tiene algo como:
  // "paths": { "@/*": ["src/*"] }
  // puedes reflejarlo aquí (VSCode permite comentarios en JSONC)
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "js"
}